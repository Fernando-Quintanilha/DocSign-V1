# ── HoleriteSign Production Environment ────────────────────
# Copy this file to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=holeritesign
POSTGRES_USER=holeritesign
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# ── JWT ─────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_STRING_WITH_AT_LEAST_32_CHARS
JWT_EXPIRATION=60

# ── SMTP ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=HoleriteSign

# ── Encryption ──────────────────────────────────────────────
# Must be at least 32 characters
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_RANDOM_STRING_WITH_AT_LEAST_32_CHARS

# ── Super Admin ─────────────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@holeritesign.com
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── URLs ────────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
API_BASE_URL=https://your-domain.com
FRONTEND_PORT=80
