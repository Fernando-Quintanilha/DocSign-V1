{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=holeritesign;Username=holeritesign;Password=CHANGE_ME;Include Error Detail=false",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS_LONG!!",
    "Issuer": "HoleriteSign",
    "Audience": "HoleriteSign",
    "ExpirationMinutes": 60
  },
  "Storage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "holeritesign",
    "UseSSL": false
  },
  "App": {
    "FrontendUrl": "http://localhost:5173",
    "BaseApiUrl": "http://localhost:5104"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "User": "CHANGE_ME",
    "Password": "CHANGE_ME",
    "From": "CHANGE_ME",
    "FromName": "HoleriteSign"
  },
  "Encryption": {
    "Key": "CHANGE_ME_IN_PRODUCTION_32_CHARS_MIN_ENCRYPTION_KEY!!"
  },
  "SuperAdmin": {
    "Email": "CHANGE_ME",
    "Password": "CHANGE_ME"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "QuotaExceededResponse": {
      "Content": "{{\"error\":\"Muitas requisições. Tente novamente em alguns minutos.\"}}",
      "ContentType": "application/json",
      "StatusCode": 429
    },
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/register",
        "Period": "1m",
        "Limit": 3
      },
      {
        "Endpoint": "POST:/api/sign/*/sign",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/sign/*/verify",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 120
      }
    ]
  }
}
